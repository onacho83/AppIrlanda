{
  "name": "imprenta-irlanda-backend",
  "version": "1.0.0",
  "description": "Backend for Imprenta Irlanda",
  "main": "dist/infrastructure/http/server.js",
  "scripts": {
    "dev": "nodemon --watch \"src/**/*.ts\" --exec ts-node src/infrastructure/http/server.ts",
    "build": "tsc",
    "start": "node dist/infrastructure/http/server.js",
    "test": "vitest run src",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "prisma db seed"
  },
  "prisma": {
    "schema": "src/infrastructure/database/prisma/schema.prisma",
    "seed": "ts-node src/infrastructure/database/prisma/seed.ts"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@fastify/cors": "^9.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@prisma/client": "^5.10.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^17.4.2",
    "fastify": "^4.26.1",
    "jsonwebtoken": "^9.0.2",
    "qrcode": "^1.5.4",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.19",
    "@types/qrcode": "^1.5.6",
    "@types/uuid": "^9.0.8",
    "nodemon": "^3.1.0",
    "prisma": "^5.10.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^4.1.8"
  }
}
